version: 2

models:
  - name: ristrutturazioni_o
    config:
      materialized: incremental
      incremental_strategy: append
      unique_key: [TP_RISTRUTTURAZIONE]
    constraints:
      - type: primary_key
        warn_unenforced: false
        columns: [TP_RISTRUTTURAZIONE]
    columns:
      - name: TP_RISTRUTTURAZIONE
        data_type: VARCHAR(1)
      - name: DS_RISTRUTTURAZIONE
        data_type: VARCHAR
      - name: F_TYP
        data_type: VARCHAR(2)


WITH
CTE_MAIN AS (
    SELECT
        null AS TP_RISTRUTTURAZIONE,
        null AS DS_RISTRUTTURAZIONE,
        null AS F_TYP
    FROM null -- TODO: aggiungere ref()
),
CTE_FTYP(
    SELECT 
CASE WHEN TP_RISTRUTTURAZIONE in ("1","2","7","8") THEN '13'
WHEN TP_RISTRUTTURAZIONE in ("3","4","A","C") THEN '03'
WHEN TP_RISTRUTTURAZIONE in ("5","D") THEN '06'
WHEN TP_RISTRUTTURAZIONE = "9" THEN '11'
WHEN TP_RISTRUTTURAZIONE = "E" THEN '14'
AS CD_FTYP
FROM Null -- TODO: aggiungere ref()
)

SELECT
    M.TP_RISTRUTTURAZIONE,
    M.DS_RISTRUTTURAZIONE,
    E.F_TYP
FROM
    CTE_MAIN AS M
    LEFT JOIN CTE_FTYP E 
    ON M.TP_RISTRUTTURAZIONE = E.TP_RISTRUTTURAZIONE



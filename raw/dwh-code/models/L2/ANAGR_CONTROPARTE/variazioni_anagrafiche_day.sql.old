        DT_SCADENZA_TESSERA_SANITARIA,
        DS_NOTE_DOCUMENTO,
        FL_UNIVOCITA_DOCUMENTO,
        FL_SOSPETTO_FORZATO_DOCUMENTO,
        DS_PRESSO,
        DS_FRAZIONE,
        DS_INDIRIZZO_1,
        DT_INDIRIZZO_RESIDENZA_DAL,
        DS_INDIRIZZO_2,
        FL_INDIRIZZO_NORMALIZZATO,
        FL_INDIRIZZO_FORZATO,
        CD_CAP,
        CD_REGIONE_RESIDENZA,
        DS_REGIONE_RESIDENZA,
        CD_NAZIONE_RESIDENZA,
        DS_NAZIONE_RESIDENZA,
        DS_COMUNE_RESIDENZA,

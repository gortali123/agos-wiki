    V.DT_SCADENZA_PERMESSO_SOGGIORNO,
    V.FL_SCADENZA_FORZATA_PERMESSO,
    V.FL_VALIDITA_FORZATA_PERMESSO,
    V.NM_CELLULARE,
    V.NM_TELEFONO,
    V.NM_TELEFONO_UFFICIO,
    V.NM_TELEFONO_SEDE,
    V.DS_FAX,
    V.DS_EMAIL,
    V.DS_EMAIL_PEC,
    V.CD_OCCUPAZIONE,
    V.CD_OCCUPAZIONE_2,
    V.DT_OCCUPAZIONE,
    V.DS_OCCUPAZIONE,
    V.CD_TIPO_ATTIVITA_OCCUPAZIONE,
    V.CD_SETTORE_OCCUPAZIONE,

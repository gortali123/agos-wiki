        V.FL_CLIENTE_BANCA,
        V.TP_CONSENSO_SRQ,
        V.TP_CONSENSO_OCI,
        V.TP_CONSENSO_OIA,
        V.TP_CONSENSO_OCE,
        V.TP_CONSENSO_OEA,

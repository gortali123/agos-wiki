        V.DT_CONSENSO_SRQ,
        V.DT_CONSENSO_OCI,
        V.DT_CONSENSO_OIA,
        V.DT_CONSENSO_OCE,
        V.DT_CONSENSO_OEA,
        V.DT_CONSENSO_OSA,
        V.DT_CONSENSO_DSU,
        V.DT_CONSENSO_CIS,

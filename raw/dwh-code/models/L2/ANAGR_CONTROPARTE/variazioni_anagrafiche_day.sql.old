        V.DS_NOTA_02,
        V.CD_FILIALE_CASELLA_POSTALE,
        V.NM_CASELLA_POSTALE,
        V.LASTMODIFIEDDATA
    FROM {{ ref('variazioni_anagrafiche') }} AS V
    -- una sola variazione per (controparte, giorno): la piu' tarda del giorno
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY V.CD_CONTROPARTE, CAST(V.TS_INIZIO_VALIDITA AS DATE)
        ORDER BY V.TS_INIZIO_VALIDITA DESC, V.PROGRESSIVO_PK DESC
    ) = 1
),

DAY AS (
    SELECT
        CD_CONTROPARTE,
        DT_INIZIO_VALIDITA,
        COALESCE(
            LEAD(DT_INIZIO_VALIDITA) OVER (
                PARTITION BY CD_CONTROPARTE ORDER BY DT_INIZIO_VALIDITA
            ),
            TO_DATE('9999-12-31')
        ) AS DT_FINE_VALIDITA,
        TP_CONTROPARTE,
        CD_FORMA_GIURIDICA,
        CD_FISCALE,
        FL_CF_CALCOLATO,
        FL_CF_FORZATO,

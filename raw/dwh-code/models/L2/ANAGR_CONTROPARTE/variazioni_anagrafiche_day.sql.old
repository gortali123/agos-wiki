        DS_FAX_DATORE_LAVORO,
        FL_DIPENDENTE,
        FL_CLIENTE,
        FL_AGENTE,
        FL_TIPO_ALTRO,
        FL_GARANTE,
        FL_FORNITORE,
        FL_COOBLIGATO,
        FL_CONVENZIONATO,
        FL_DITTA,
        FL_FIRMATARIO,
        FL_DELEGATO,
        FL_FONDO_PENSIONE,
        FL_FINANZIARIA,
        FL_DATORE_LAVORO,
        TP_INTERMEDIARIO_ABILITATO,
        FL_ANA_DI_GRUPPO,
        FL_CLIENTE_BANCA,
        TP_CONSENSO_SRQ,
        TP_CONSENSO_OCI,
        TP_CONSENSO_OIA,
        TP_CONSENSO_OCE,
        TP_CONSENSO_OEA,
        TP_CONSENSO_OSA,
        TP_CONSENSO_DSU,

        CD_FILIALE,
        CD_FILIALE_STORICA,
        CD_ESENZIONE_IVA,
        CD_SETTORE_ATTIVITA,
        DS_ATECO,
        CD_ATECO,
        CD_RAE,
        DS_RAE,
        CD_SAE,
        DS_SAE,
        CD_TAE,
        CD_CCIAA,
        TP_CCIAA,
        CD_PROVINCIA_CCIAA,
        DS_PROVINCIA_CCIAA,
        DT_REGISTRAZIONE_CCIAA,
        FL_CONTROLLO_CCIAA,
        FL_FALLIBILE,
        DT_FALLIMENTO,
        TP_PROC_CONCORSUALI,
        TP_PROC_LEGALI,

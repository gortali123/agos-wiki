    V.FL_CONVENZIONATO,
    V.FL_DITTA,
    V.FL_FIRMATARIO,
    V.FL_DELEGATO,
    V.FL_FONDO_PENSIONE,
    V.FL_FINANZIARIA,
    V.FL_DATORE_LAVORO,
    V.TP_INTERMEDIARIO_ABILITATO,
    V.FL_ANA_DI_GRUPPO,
    V.FL_CLIENTE_BANCA,
    V.TP_CONSENSO_SRQ,
    V.TP_CONSENSO_OCI,
    V.TP_CONSENSO_OIA,
    V.TP_CONSENSO_OCE,
    V.TP_CONSENSO_OEA,
    V.TP_CONSENSO_OSA,
    V.TP_CONSENSO_DSU,
    V.TP_CONSENSO_SIC,
    V.TP_CONSENSO_IPR,
    V.DT_CONSENSO_IPR,
    V.DT_CONSENSO_SRQ,
    V.DT_CONSENSO_OCI,
    V.DT_CONSENSO_OIA,
    V.DT_CONSENSO_OCE,
    V.DT_CONSENSO_OEA,
    V.DT_CONSENSO_OSA,
    V.DT_CONSENSO_DSU,
    V.DT_CONSENSO_CIS,
    V.DS_NOTE_SIC,
    V.TP_CANCELLAZIONE_DATI_PRIVACY,
    V.EU_REDDITO_ANNUO,
    V.NM_MENSILITA_REDDITO,
    V.EU_ALTRI_REDDITI,
    V.TP_REDDITO,
    V.EU_REDDITO_FAMILIARE,
    V.EU_REDDITO_FAMILIARE_CONIUGE,
    V.CD_CENTRALE_RISCHI,
    V.CD_SIA,
    V.CD_LEGALE_RAPPRESENTANTE,
    V.DS_NOME_LEGALE_RAPPRESENTANTE,
    V.DS_INDIRIZZO_LEGALE_RAPPRESENTANTE,
    V.DS_PRESSO_LEGALE_RAPPRESENTANTE,
    V.CD_CAP_LEGALE_RAPPRESENTANTE,
    V.DS_FRAZIONE_LEGALE_RAPPRESENTANTE,
    V.DS_COMUNE_LEGALE_RAPPRESENTANTE,
    V.CD_PROVINCIA_LEGALE_RAPPRESENTANTE,
    V.DS_PROVINCIA_LEGALE_RAPPRESENTANTE,
    V.DT_NASCITA_LEGALE_RAPPRESENTANTE,
    V.DS_LOUGO_NASCITA_LEGALE_RAPPRESENTANTE,
    V.CD_PROVINCIA_NASCITA_LEGALE_RAPPRESENTANTE,
    V.DS_PROVINCIA_NASCITA_LEGALE_RAPPRESENTANTE,
    V.CD_NAZIONE_NASCITA_LEGALE_RAPPRESENTANTE,
    V.DS_NAZIONE_NASCITA_LEGALE_RAPPRESENTANTE,
    V.CD_CITTADINANZA_LEGALE_RAPPRESENTANTE,
    V.DS_CITTADINANZA_LEGALE_RAPPRESENTANTE,
    V.CD_CAUSALE_ANNULLO,
    V.DT_ANNULLO,
    V.DT_INSERIMENTO,
    V.CD_UTENTE_INSERIMENTO,
    V.DT_VARIAZIONE,
    V.CD_UTENTE_VARIAZIONE,
    V.DT_TRASMISSIONE,
    V.DS_STRINGA_RICERCA,
    V.CD_USER_1,
    V.CD_USER_2,
    V.CD_USER_3,
    V.FL_NORM_DENOMINAZIONE,
    V.FL_NORM_LOCALITA,
    V.FL_NORM_INDIRIZZO,
    V.DS_NOTA_01,
    V.DS_NOTA_02,
    V.CD_FILIALE_CASELLA_POSTALE,
    V.NM_CASELLA_POSTALE,
    V.LASTMODIFIEDDATA
FROM {{ ref('variazioni_anagrafiche') }} AS V
{% if is_incremental() %}
WHERE V.CD_CONTROPARTE IN (
    SELECT DISTINCT S.CD_CONTROPARTE
    FROM {{ ref('variazioni_anagrafiche') }} AS S
    WHERE S.LASTMODIFIEDDATA > (
        SELECT COALESCE(MAX(T.LASTMODIFIEDDATA), '1900-01-01'::TIMESTAMP_NTZ)
        FROM {{ this }} AS T
    )
)
{% endif %}
QUALIFY ROW_NUMBER() OVER (
    PARTITION BY V.CD_CONTROPARTE, CAST(V.TS_INIZIO_VALIDITA AS DATE)
    ORDER BY V.TS_INIZIO_VALIDITA DESC, V.PROGRESSIVO_PK DESC
) = 1

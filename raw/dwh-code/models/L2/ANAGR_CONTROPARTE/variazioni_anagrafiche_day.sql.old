    V.NM_CAPITALE_SOCIALE,
    V.FL_PARTECIPATA_ENTE_PUBBLICO,
    V.DS_DATORE_LAVORO,
    V.CD_FISCALE_DATORE_LAVORO,
    V.CD_PARTITA_IVA_DATORE_LAVORO,
    V.CD_FORMA_GIURIDICA_DATORE_LAVORO,
    V.CD_IDEN_DATORE_LAVORO,
    V.DS_INDIRIZZO_DATORE_LAVORO,
    V.DS_PRESSO_DATORE_LAVORO,
    V.DS_COMUNE_DATORE_LAVORO,
    V.CD_CAP_INDIRIZZO_DATORE_LAVORO,
    V.DS_FRAZIONE_DATORE_LAVORO,
    V.CD_PROVINCIA_DATORE_LAVORO,
    V.DS_PROVINCIA_DATORE_LAVORO,
    V.NM_TELEFONO_DATORE_LAVORO,
    V.FL_INDIRIZZO_NORMALIZZATO_DATORE_LAVORO,

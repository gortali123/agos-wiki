FROM DAY
{% if is_incremental() -%}
WHERE
    LASTMODIFIEDDATA > (
        SELECT COALESCE(MAX(LASTMODIFIEDDATA), '1900-01-01'::TIMESTAMP_NTZ)
        FROM {{ this }}
    )
    OR (
        DT_FINE_VALIDITA > (
            SELECT COALESCE(MAX(DT_INIZIO_VALIDITA), '1900-01-01'::DATE)
            FROM {{ this }}
        )
        AND DT_FINE_VALIDITA < TO_DATE('9999-12-31')
    )
{%- endif %}

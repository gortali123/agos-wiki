    DS_INDIRIZZO_1,
    DT_INDIRIZZO_RESIDENZA_DAL,
    DS_INDIRIZZO_2,
    FL_INDIRIZZO_NORMALIZZATO,
    FL_INDIRIZZO_FORZATO,
    CD_CAP,

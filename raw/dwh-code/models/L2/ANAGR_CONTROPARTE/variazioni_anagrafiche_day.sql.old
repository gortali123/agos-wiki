SELECT
    V.CD_CONTROPARTE,
    CAST(V.TS_INIZIO_VALIDITA AS DATE) AS DT_INIZIO_VALIDITA,
    COALESCE(
        CAST(
            LEAD(V.TS_INIZIO_VALIDITA) OVER (
                PARTITION BY V.CD_CONTROPARTE
                ORDER BY V.TS_INIZIO_VALIDITA, V.PROGRESSIVO_PK
            ) AS DATE
        ),
        TO_DATE('9999-12-31')
    ) AS DT_FINE_VALIDITA,
    V.TP_CONTROPARTE,
    V.CD_FORMA_GIURIDICA,
    V.CD_FISCALE,
    V.FL_CF_CALCOLATO,
    V.FL_CF_FORZATO,
    V.CD_UTENTE_FORZATURA_CF,
    V.CD_PARTITA_IVA,
    V.DS_NOME,
    V.DS_SECONDO_NOME,
    V.DS_COGNOME,
    V.DS_COGNOME_MADRE,
    V.CD_RIFERIMENTO_ALTRA_ANAGRAFICA,
    V.CD_MATRICOLA,
    V.DS_RAGIONE_SOCIALE,
    V.DS_RAGIONE_SOCIALE_2,
    V.CD_CITTADINANZA,
    V.DS_CITTADINANZA,
    V.DS_CITTA_NASCITA,
    V.CD_NAZIONE_NASCITA,
    V.DS_NAZIONE_NASCITA,
    V.CD_PROVINCIA_NASCITA,
    V.DS_PROVINCIA_NASCITA,
    V.DS_COMUNE_NASCITA,
    V.CD_CAB_COMUNE_NASCITA,
    V.DT_NASCITA,
    V.CD_SESSO,
    V.DT_DECESSO,
    V.CD_ABI,
    V.CD_IDENTIFICATIVO,
    V.CD_NDG,
    V.CD_NDG2,
    V.CD_NDG3,
    V.CD_NDG_CRF,
    V.CD_INPS_MATRICOLA,
    V.CD_INAIL_PAT,
    V.CD_IPA,
    V.CD_FILIALE,
    V.CD_FILIALE_STORICA,
    V.CD_ESENZIONE_IVA,
    V.CD_SETTORE_ATTIVITA,
    V.DS_ATECO,
    V.CD_ATECO,
    V.CD_RAE,
    V.DS_RAE,
    V.CD_SAE,
    V.DS_SAE,
    V.CD_TAE,
    V.CD_CCIAA,
    V.TP_CCIAA,
    V.CD_PROVINCIA_CCIAA,
    V.DS_PROVINCIA_CCIAA,
    V.DT_REGISTRAZIONE_CCIAA,
    V.FL_CONTROLLO_CCIAA,
    V.FL_FALLIBILE,
    V.DT_FALLIMENTO,
    V.TP_PROC_CONCORSUALI,
    V.TP_PROC_LEGALI,
    V.CD_DOCUMENTO,
    V.TP_DOCUMENTO,
    V.TP_EMITTENTE,
    V.DT_RILASCIO_DOC,
    V.DT_FINE_VALIDITA_DOC,
    V.DS_COMUNE_RILASCIO_DOC,
    V.CD_PROVINCIA_RILASCIO_DOC,
    V.DS_PROVINCIA_RILASCIO_DOC,
    V.CD_NAZIONE_RILASCIO_DOC,
    V.DS_NAZIONE_RILASCIO_DOC,
    V.CD_DOCUMENTO_2,
    V.NM_TESSERA_SANITARIA,
    V.DT_SCADENZA_TESSERA_SANITARIA,
    V.DS_NOTE_DOCUMENTO,
    V.FL_UNIVOCITA_DOCUMENTO,
    V.FL_SOSPETTO_FORZATO_DOCUMENTO,
    V.DS_PRESSO,
    V.DS_FRAZIONE,
    V.DS_INDIRIZZO_1,
    V.DT_INDIRIZZO_RESIDENZA_DAL,
    V.DS_INDIRIZZO_2,
    V.FL_INDIRIZZO_NORMALIZZATO,
    V.FL_INDIRIZZO_FORZATO,
    V.CD_CAP,
    V.CD_REGIONE_RESIDENZA,
    V.DS_REGIONE_RESIDENZA,
    V.CD_NAZIONE_RESIDENZA,
    V.DS_NAZIONE_RESIDENZA,
    V.DS_COMUNE_RESIDENZA,
    V.CD_PROVINCIA_RESIDENZA,
    V.DS_PROVINCIA_RESIDENZA,
    V.CD_CAB_RESIDENZA,
    V.CD_TIPO_SEDE,
    V.DS_SEDE_INDIRIZZO_1,
    V.DS_SEDE_INDIRIZZO_2,
    V.FL_SEDE_INDIRIZZO_NORMALIZZATO,
    V.FL_SEDE_INDIRIZZO_FORZATO,
    V.DS_SEDE_PRESSO,
    V.DS_SEDE_FRAZIONE,
    V.DS_SEDE_REGIONE,
